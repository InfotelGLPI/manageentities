<div class="card mt-3">

    <div class="card-header">
        <h3 class="card-title">
            <i class="ti ti-file-report me-2"></i>
            {{ __('Associated intervention reports', 'manageentities') }}
        </h3>
        {% if entries|length > 0 %}
            <span class="badge bg-outline-secondary ms-1">{{ entries|length }}</span>
        {% endif %}
        {% if all_reports_url %}
            <a href="{{ all_reports_url }}" class="ms-auto btn btn-sm btn-outline-secondary">
                <i class="ti ti-list me-1"></i>{{ __('All reports', 'manageentities') }}
            </a>
        {% endif %}
    </div>

    {% if entries|length > 0 %}
    <div class="card-body p-0">
        {{ include('components/datatable.html.twig', {
            'datatable_id': 'cri_reports_table',
            'nosort': true,
            'nofilter': true,
            'columns': columns,
            'formatters': formatters,
            'entries': entries,
            'total_number': entries|length,
            'filtered_number': entries|length,
            'table_class_style': 'table-hover table-sm'
        }) }}
    </div>
    {% if add_reports_html %}
    <div class="card-footer">
        {{ add_reports_html|raw }}
    </div>
    {% endif %}

    {% else %}
    <div class="card-body">
        <div class="alert alert-info d-flex align-items-center gap-2 mb-0">
            <i class="ti ti-info-circle"></i>
            {{ __('No reports found', 'manageentities') }}
        </div>
        {% if add_reports_html %}
        <div class="mt-2">
            {{ add_reports_html|raw }}
        </div>
        {% endif %}
    </div>
    {% endif %}
</div>
