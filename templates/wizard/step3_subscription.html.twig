{#
 Step 3 — Publisher subscription (new_entity mode only, optional)
 Variables: sub_name, customer_account_id, active_editor_suscription, cloud_client,
            internet_publication, plugin_manageentities_subscriptionlevels_id, all_levels,
            begin_date, end_date, end_date_expired, comment, rand, wizard_url, step
 #}

<div class="card">
    <div class="card-header d-flex align-items-center gap-2">
        <i class="ti ti-certificate me-1"></i>
        <h3 class="card-title mb-0">
            {{ __('Publisher subscription', 'manageentities') }}
            <small class="text-muted fw-normal ms-1">{{ __('Optional') }}</small>
        </h3>
    </div>
    <div class="card-body">
        <div id="step3-errors" class="alert alert-danger d-none"></div>

        <div class="row g-3" id="step3-fields-{{ rand }}">
            {% include '@manageentities/editorsubscription_fields.html.twig' with {
                fields_required: false,
                container_id: 'step3-fields-' ~ rand,
                load_entity_ajax: false
            } %}
        </div>
    </div>
    <div class="card-footer d-flex gap-2 justify-content-between">
        <button type="button" class="btn btn-outline-secondary"
            onclick="wizardBack({{ step }}, '{{ wizard_url }}')">
            <i class="ti ti-arrow-left me-1"></i>{{ __('Previous') }}
        </button>
        <button type="button" class="btn btn-primary"
            onclick="wizardSaveStep(3, '{{ wizard_url }}')">
            <i class="ti ti-arrow-right me-1"></i>{{ __('Next') }}
        </button>
    </div>
</div>

{% include '@manageentities/editorsubscription_fields_js.html.twig' with {
    container_id: 'step3-fields-' ~ rand,
    fields_required: false,
    load_entity_ajax: false
} %}
