{#
 Step 1 — Entity
 Variables: entity_fields, entities_html, rand, wizard_url
 #}

<div class="card">
    <div class="card-header d-flex align-items-center gap-2">
        <i class="ti ti-building me-1"></i>
        <h3 class="card-title mb-0">{{ __('New entity', 'manageentities') }}</h3>
    </div>
    <div class="card-body">
        <div id="step1-errors" class="alert alert-danger d-none"></div>
        <div class="row g-3">

            <div class="col-sm-6">
                <label class="col-form-label fw-bold">{{ __('Name') }} <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control" required
                    autocomplete="off"
                    {% if name_suggestions is not empty %}list="entity-name-suggestions"{% endif %}
                    value="{{ entity_fields.name ?? '' }}">
                {% if name_suggestions is not empty %}
                    <datalist id="entity-name-suggestions">
                        {% for suggestion in name_suggestions %}
                            <option value="{{ suggestion }}">
                        {% endfor %}
                    </datalist>
                {% endif %}
            </div>
            <div class="col-sm-6">
                <label class="col-form-label fw-bold">{{ __('Parent entity', 'manageentities') }}</label>
                {% if parent_entity_locked %}
                    <div class="d-flex align-items-center gap-2">
                        {{ entities_html|raw }}
                        <span class="badge bg-outline-secondary" title="{{ __('Set in configuration', 'manageentities') }}">
                            <i class="ti ti-lock"></i>
                        </span>
                    </div>
                {% else %}
                    {{ entities_html|raw }}
                {% endif %}
            </div>

            <div class="col-sm-6">
                <label class="col-form-label fw-bold">{{ __('Phone') }}</label>
                <input type="text" name="phonenumber" class="form-control"
                    value="{{ entity_fields.phonenumber ?? '' }}">
            </div>
            <div class="col-sm-6">
                <label class="col-form-label fw-bold">{{ __('Fax') }}</label>
                <input type="text" name="fax" class="form-control"
                    value="{{ entity_fields.fax ?? '' }}">
            </div>

            <div class="col-sm-6">
                <label class="col-form-label fw-bold">{{ __('Email') }}</label>
                <input type="email" name="email" class="form-control"
                    value="{{ entity_fields.email ?? '' }}">
            </div>
            <div class="col-sm-6">
                <label class="col-form-label fw-bold">{{ __('Website') }}</label>
                <input type="text" name="website" class="form-control"
                    value="{{ entity_fields.website ?? '' }}">
            </div>

            <div class="col-sm-12">
                <label class="col-form-label fw-bold">{{ __('Address') }}</label>
                <input type="text" name="address" class="form-control"
                    value="{{ entity_fields.address ?? '' }}">
            </div>
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Postal code') }}</label>
                <input type="text" name="postcode" class="form-control"
                    value="{{ entity_fields.postcode ?? '' }}">
            </div>
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('City') }}</label>
                <input type="text" name="town" class="form-control"
                    value="{{ entity_fields.town ?? '' }}">
            </div>
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('State') }}</label>
                <input type="text" name="state" class="form-control"
                    value="{{ entity_fields.state ?? '' }}">
            </div>
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Country') }}</label>
                <input type="text" name="country" class="form-control"
                    value="{{ entity_fields.country ?? '' }}">
            </div>

            <div class="col-sm-12">
                <label class="col-form-label fw-bold">{{ __('Comments') }}</label>
                <textarea name="comment" class="form-control" rows="3">{{ entity_fields.comment ?? '' }}</textarea>
            </div>

        </div>
    </div>
    <div class="card-footer d-flex gap-2 justify-content-end">
        <button type="button" class="btn btn-primary" onclick="wizardSaveStep(1, '{{ wizard_url }}')">
            <i class="ti ti-arrow-right me-1"></i>{{ __('Next') }}
        </button>
    </div>
</div>
