{#
 Wizard mode choice — displayed before any step when no mode is selected.
 Variables: wizard_url
 #}

<div id="wizard-addelements">
    <div class="text-center mb-4">
        <h2>{{ __('Entities portal', 'manageentities') }}</h2>
        <p class="text-muted">{{ __('What would you like to do?', 'manageentities') }}</p>
    </div>

    <div class="row g-4 justify-content-center">

        <div class="col-sm-5">
            <div class="card h-100 border-2 cursor-pointer" style="cursor:pointer"
                 onclick="wizardChooseMode('new_entity', WIZARD_URL)">
                <div class="card-body text-center py-5">
                    <i class="ti ti-building-plus text-primary" style="font-size:3rem"></i>
                    <h4 class="mt-3">{{ __('New client', 'manageentities') }}</h4>
                    <p class="text-muted">{{ __('Create a new entity, contacts, contract and service periods.', 'manageentities') }}</p>
                    <button type="button" class="btn btn-primary mt-2">
                        <i class="ti ti-arrow-right me-1"></i>{{ __('Start', 'manageentities') }}
                    </button>
                </div>
            </div>
        </div>

        <div class="col-sm-5">
            <div class="card h-100 border-2" style="cursor:pointer"
                 onclick="wizardChooseMode('existing_entity', WIZARD_URL)">
                <div class="card-body text-center py-5">
                    <i class="ti ti-file-plus text-success" style="font-size:3rem"></i>
                    <h4 class="mt-3">{{ __('New contract', 'manageentities') }}</h4>
                    <p class="text-muted">{{ __('Add a new contract and service periods to an existing client.', 'manageentities') }}</p>
                    <button type="button" class="btn btn-success mt-2">
                        <i class="ti ti-arrow-right me-1"></i>{{ __('Start', 'manageentities') }}
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    var WIZARD_URL = {{ wizard_url|json_encode|raw }};
</script>
