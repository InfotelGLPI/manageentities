{#
 Step 1 (existing_entity mode) — Select an existing entity
 Variables: entity_select_html, rand, wizard_url
 #}

<div class="card">
    <div class="card-header d-flex align-items-center gap-2">
        <i class="ti ti-building-search me-1"></i>
        <h3 class="card-title mb-0">{{ __('Select an existing entity', 'manageentities') }}</h3>
    </div>
    <div class="card-body">
        <div id="step1-errors" class="alert alert-danger d-none"></div>
        <div class="row g-3">
            <div class="col-sm-6">
                <label class="col-form-label fw-bold">
                    {{ __('Entity') }} <span class="text-danger">*</span>
                </label>
                {{ entity_select_html|raw }}
            </div>
        </div>
    </div>
    <div class="card-footer d-flex gap-2 justify-content-end">
        <button type="button" class="btn btn-primary" onclick="wizardSaveStep(1, '{{ wizard_url }}')">
            <i class="ti ti-arrow-right me-1"></i>{{ __('Next') }}
        </button>
    </div>
</div>
