{% set form_id = 'contract_form' ~ rand %}

{# ------------------------------------------------------------------ #}
{# Publisher subscription — read-only summary                          #}
{# ------------------------------------------------------------------ #}
{% if has_subscription %}
<div class="card mt-3">
    <div class="card-header d-flex align-items-center gap-2">
        <h3 class="card-title">
            <i class="ti ti-certificate me-2"></i>
            {{ __('Publisher subscription', 'manageentities') }}
        </h3>
        {% if can_edit %}
        <div class="card-options ms-auto">
            <a href="{{ sub_wizard_url }}" class="btn btn-sm btn-outline-primary">
                <i class="ti ti-pencil me-1"></i>{{ __('Edit') }}
            </a>
        </div>
        {% endif %}
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Type', 'manageentities') }}</label>
                <p class="form-control-plaintext">
                    {% if sub_cloud %}
                        <span class="badge bg-outline-info"><i class="ti ti-cloud me-1"></i>{{ __('Cloud client', 'manageentities') }}</span>
                    {% else %}
                        <span class="badge bg-outline-success"><i class="ti ti-certificate me-1"></i>{{ __('Editor subscription', 'manageentities') }}</span>
                    {% endif %}
                </p>
            </div>
            {% if sub_customer_account_id %}
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Publisher customer account ID', 'manageentities') }}</label>
                <p class="form-control-plaintext">{{ sub_customer_account_id }}</p>
            </div>
            {% endif %}
            {% if sub_name %}
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Referenced name at the publisher', 'manageentities') }}</label>
                <p class="form-control-plaintext">{{ sub_name }}</p>
            </div>
            {% endif %}
            {% if sub_level_name %}
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Subscription level', 'manageentities') }}</label>
                <p class="form-control-plaintext">{{ sub_level_name }}</p>
            </div>
            {% endif %}
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Internet publication', 'manageentities') }}</label>
                <p class="form-control-plaintext">
                    {% if internet_publication %}
                        <span class="badge bg-outline-cyan"><i class="ti ti-world me-1"></i>{{ __('Yes') }}</span>
                    {% else %}
                        <span class="text-muted">{{ __('No') }}</span>
                    {% endif %}
                </p>
            </div>
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Start date', 'manageentities') }}</label>
                <p class="form-control-plaintext">
                    {{ sub_begin_date ? sub_begin_date|date('d/m/Y') : '—' }}
                </p>
            </div>
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('End date', 'manageentities') }}</label>
                <p class="form-control-plaintext {% if sub_end_expired %}text-danger fw-bold{% endif %}">
                    {{ sub_end_date ? sub_end_date|date('d/m/Y') : '—' }}
                    {% if sub_end_expired %}<i class="ti ti-alert-circle ms-1"></i>{% endif %}
                </p>
            </div>
        </div>
    </div>
</div>
{% endif %}

{% if can_edit %}
<form method="post" name="{{ form_id }}" id="{{ form_id }}" action="{{ form_url }}">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
    <input type="hidden" name="contracts_id" value="{{ contracts_id }}">
    <input type="hidden" name="entities_id"  value="{{ entities_id }}">
    {% if not is_new %}
        <input type="hidden" name="id" value="{{ plugin_contract_id }}">
    {% endif %}
{% endif %}

<div class="card mt-3">
    <div class="card-header d-flex align-items-center gap-2">
        <h3 class="card-title">
            <i class="ti ti-file-invoice me-2"></i>
            {{ __('Management type', 'manageentities') }}
        </h3>
    </div>
    <div class="card-body">
        <div class="row g-3">

            {# Date de signature / Date de renouvellement #}
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Date of signature', 'manageentities') }}</label>
                {{ date_signature_html|raw }}
            </div>
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Date of renewal', 'manageentities') }}</label>
                {{ date_renewal_html|raw }}
            </div>

            {% if is_hour_mode %}
            {# Mode de gestion / Type de contrat (mode heure) #}
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Mode of management', 'manageentities') }}</label>
                {{ management_html|raw }}
            </div>
            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Type of service contract', 'manageentities') }}</label>
                {{ contract_type_html|raw }}
            </div>
            {% else %}
            <div class="col-sm-6"></div>
            {% endif %}

            {# Switches ligne 1 : GANTT / Coûts refacturables / Contrat importé GLPI / Souscription active #}

            {% if is_day_price %}
                <div class="col-sm-3">
                    <label class="col-form-label fw-bold">{{ __('Contract is imported in GLPI', 'manageentities') }}</label>
                    <div class="form-check form-switch mt-2">
                        <input type="checkbox" name="contract_added" class="form-check-input"
                               {% if contract_added %}checked{% endif %}>
                    </div>
                </div>
            {% endif %}

            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Show on GANTT', 'manageentities') }}</label>
                <div class="form-check form-switch mt-2">
                    <input type="checkbox" name="show_on_global_gantt" class="form-check-input"
                        {% if show_on_global_gantt %}checked{% endif %}>
                </div>
            </div>

            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Refacturable costs', 'manageentities') }}</label>
                <div class="form-check form-switch mt-2">
                    <input type="checkbox" name="refacturable_costs" class="form-check-input"
                           {% if refacturable_costs %}checked{% endif %}>
                </div>
            </div>
            <div class="col-sm-3"></div>

            {# Internet / Déplacements #}
            <div class="col-sm-3"></div>

            <div class="col-sm-3">
                <label class="col-form-label fw-bold">{{ __('Movement management', 'manageentities') }}</label>
                <div class="form-check form-switch mt-2">
                    <input type="checkbox" name="moving_management" id="moving_management_{{ rand }}" class="form-check-input"
                        {% if moving_management %}checked{% endif %}
                        onchange="document.getElementById('movement_block_{{ rand }}').style.display = this.checked ? '' : 'none'">
                </div>
            </div>

            {# Durée des déplacements (conditionnelle) #}
            <div class="col-sm-3" id="movement_block_{{ rand }}"{% if not moving_management %} style="display:none"{% endif %}>
                <label class="col-form-label fw-bold">{{ __('Duration of moving', 'manageentities') }}</label>
                {{ duration_moving_html|raw }}
            </div>

        </div>
    </div>

    {% if can_edit %}
    <div class="card-footer d-flex gap-2 justify-content-end">
        {% if is_new %}
            <button type="submit" name="addcontract" class="btn btn-primary">
                <i class="ti ti-plus me-1"></i>{{ __('Add') }}
            </button>
        {% else %}
            <button type="submit" name="updatecontract" class="btn btn-primary">
                <i class="ti ti-device-floppy me-1"></i>{{ __('Update') }}
            </button>
            <button type="submit" name="delcontract" class="btn btn-danger">
                <i class="ti ti-trash me-1"></i>{{ __('Delete permanently') }}
            </button>
        {% endif %}
    </div>
    {% endif %}
</div>

{% if can_edit %}
</form>
{% endif %}
