{% import "components/form/fields_macros.html.twig" as fields %}

<div class="asset">
    {% include("components/form/header.html.twig") %}

    <input type="hidden" name="plugin_manageentities_contractdays_id" value="{{ contractdays_id }}">
    <input type="hidden" name="entities_id" value="{{ entities_id }}">

    <div class="card-body d-flex flex-wrap gap-3 pt-0">
        <div class="col-12">
            <div class="row flex-row">

                {# Intervention type #}
                {{ fields.field('plugin_manageentities_critypes_id', critype_html,
                    __('Intervention type', 'manageentities'), {
                    'required': true
                }) }}

                {# Price #}
                {{ fields.textField('price', price, price_label, {
                    'required': true
                }) }}

                {# Is default #}
                {{ fields.field('is_default', is_default_html, __('Is default', 'manageentities')) }}

                {# Select an existing price #}
                {% set select_price_with_div %}
                    <div id="manageentities_loadPrice">{{ select_price_html|raw }}</div>
                {% endset %}
                {{ fields.field('select_critype', select_price_with_div,
                    __('Select an existing price', 'manageentities')) }}

            </div>
        </div>
    </div>

    {% include("components/form/buttons.html.twig") %}
</div>

<script type="text/javascript">
function manageentities_loadSelectPrice() {
    $.ajax({
        url:  '{{ ajax_url }}',
        type: 'POST',
        data: {
            action:      'loadPrice',
            critypes_id: $('#dropdown_plugin_manageentities_critypes_id{{ rand_critype }}').val(),
            entities_id: {{ entities_id }}
        },
        success: function(html) {
            $('#manageentities_loadPrice').html(html);
        }
    });
}
</script>
