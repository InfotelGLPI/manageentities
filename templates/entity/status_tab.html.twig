<div class="card mt-3">
    <div class="card-header">
        <h3 class="card-title">
            <i class="ti ti-clipboard-check me-2"></i>
            {{ __('Status overview', 'manageentities') }}
        </h3>
    </div>
    <div class="card-body">
        <div class="row g-3">

            {# Left column: alert 1 (no subscription) + alert 2 (expired) #}
            <div class="col-8 col-lg-6 d-flex flex-column gap-3">

                {# Alert 1: entities with active contract but no subscription #}
                {% if no_subscription|length > 0 %}
                <div class="alert alert-danger d-flex align-items-start gap-2 mb-0" role="alert">
                    <i class="ti ti-alert-triangle flex-shrink-0 mt-1"></i>
                    <div>
                        <strong>{{ __('Entities with an active contract but no publisher subscription:', 'manageentities') }}</strong>
                        <ul class="mb-0 mt-1">
                            {% for name in no_subscription %}
                                <li>{{ name }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
                {% else %}
                <div class="alert alert-success d-flex align-items-center gap-2 mb-0" role="alert">
                    <i class="ti ti-circle-check flex-shrink-0"></i>
                    {{ __('All entities with an active contract have a publisher subscription.', 'manageentities') }}
                </div>
                {% endif %}

                {# Alert 2: entities with an expired subscription #}
                {% set has_expired = expired_subscription.cloud|length > 0 or expired_subscription.onpremise|length > 0 %}
                {% if has_expired %}
                <div class="alert alert-danger d-flex align-items-start gap-2 mb-0" role="alert">
                    <i class="ti ti-clock-exclamation flex-shrink-0 mt-1"></i>
                    <div class="w-100">
                        <strong>{{ __('Entities with an expired publisher subscription:', 'manageentities') }}</strong>
                        <div class="row mt-2 g-2">
                            {% if expired_subscription.cloud|length > 0 %}
                            <div class="col-12 col-md-6">
                                <div class="fw-semibold mb-1"><i class="ti ti-cloud me-1"></i>{{ __('Cloud', 'manageentities') }}</div>
                                <ul class="mb-0">
                                    {% for name in expired_subscription.cloud %}
                                        <li>{{ name }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                            {% endif %}
                            {% if expired_subscription.onpremise|length > 0 %}
                            <div class="col-12 col-md-6">
                                <div class="fw-semibold mb-1"><i class="ti ti-server me-1"></i>{{ __('On-premise', 'manageentities') }}</div>
                                <ul class="mb-0">
                                    {% for name in expired_subscription.onpremise %}
                                        <li>{{ name }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% else %}
                <div class="alert alert-success d-flex align-items-center gap-2 mb-0" role="alert">
                    <i class="ti ti-circle-check flex-shrink-0"></i>
                    {{ __('No expired publisher subscription.', 'manageentities') }}
                </div>
                {% endif %}

            </div>

            {# Vertical divider #}
            <div class="col-auto d-none d-lg-flex">
                <div class="vr"></div>
            </div>

            {# Right column: alert 3 (no contract) + subscription counts #}
            <div class="col-12 col-lg d-flex flex-column gap-4">

                {# Alert 3: entities with subscription but no active contract #}
                {% set has_no_contract = no_contract.had_contract|length > 0 or no_contract.never_contract|length > 0 %}
                {% if has_no_contract %}
                <div class="alert alert-warning d-flex align-items-start gap-2 mb-0" role="alert">
                    <i class="ti ti-alert-circle flex-shrink-0 mt-1"></i>
                    <div class="w-100">
                        <strong>{{ __('Entities with a publisher subscription but no active contract:', 'manageentities') }}</strong>
                        <div class="row mt-2 g-2">
                            {% if no_contract.had_contract|length > 0 %}
                            <div class="col-12 col-md-6">
                                <div class="fw-semibold mb-1"><i class="ti ti-history me-1"></i>{{ __('Previously had a contract', 'manageentities') }}</div>
                                <ul class="mb-0">
                                    {% for name in no_contract.had_contract %}
                                        <li>{{ name }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                            {% endif %}
                            {% if no_contract.never_contract|length > 0 %}
                            <div class="col-12 col-md-6">
                                <div class="fw-semibold mb-1"><i class="ti ti-file-x me-1"></i>{{ __('Never had a contract', 'manageentities') }}</div>
                                <ul class="mb-0">
                                    {% for name in no_contract.never_contract %}
                                        <li>{{ name }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% else %}
                <div class="alert alert-success d-flex align-items-center gap-2 mb-0" role="alert">
                    <i class="ti ti-circle-check flex-shrink-0"></i>
                    {{ __('All entities with a publisher subscription have an active contract.', 'manageentities') }}
                </div>
                {% endif %}

                {# By type #}
                <div>
                    <h4 class="text-muted mb-3 fs-5">
                        <i class="ti ti-layout-grid me-1"></i>
                        {{ __('Subscriptions by type', 'manageentities') }}
                    </h4>
                    <div class="d-flex gap-2">
                        <div class="card text-center border-2 flex-shrink-0 flex-grow-1">
                            <div class="card-body p-3">
                                <div class="display-6 fw-bold text-info">{{ type_counts.cloud }}</div>
                                <div class="text-muted small mt-1">
                                    <i class="ti ti-cloud me-1"></i>{{ __('Cloud', 'manageentities') }}
                                </div>
                            </div>
                        </div>
                        <div class="card text-center border-2 flex-shrink-0 flex-grow-1">
                            <div class="card-body p-3">
                                <div class="display-6 fw-bold text-success">{{ type_counts.onpremise }}</div>
                                <div class="text-muted small mt-1">
                                    <i class="ti ti-server me-1"></i>{{ __('On-premise', 'manageentities') }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {# By level #}
                <div>
                    <h4 class="text-muted mb-3 fs-5">
                        <i class="ti ti-certificate me-1"></i>
                        {{ __('Subscriptions by level', 'manageentities') }}
                    </h4>
                    {% if level_counts|length > 0 %}
                    <div class="d-flex flex-wrap gap-2">
                        {% for item in level_counts %}
                        <div class="card text-center border-2 flex-shrink-0" style="min-width:110px">
                            <div class="card-body p-3">
                                <div class="display-6 fw-bold text-primary">{{ item.count }}</div>
                                <div class="text-muted small mt-1">{{ item.name }}</div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <p class="text-muted">{{ __('No subscription recorded.', 'manageentities') }}</p>
                    {% endif %}
                </div>

            </div>

        </div>
    </div>
</div>
