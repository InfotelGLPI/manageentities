<div class="row g-3 mt-1">

    {# ── Left column — one card per entity ── #}
    <div class="col-12 col-xl-7">

        {% for ent in entities_data %}
        <div class="card {% if not loop.first %}mt-3{% endif %}">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-building me-1"></i>
                    {{ __('Data administrative', 'manageentities') }}
                    {% if not is_single %}
                        <span class="text-muted small ms-2">— {{ ent.entity_name }}</span>
                    {% endif %}
                </h3>
            </div>
            <div class="card-body">

                {# Logo row #}
                {% if ent.logos is not empty or can_edit %}
                <div class="row mb-3 align-items-center">
                    <dt class="col-sm-3 text-sm-end text-muted small fw-semibold mb-0">{{ __('Logo') }}</dt>
                    <dd class="col-sm-9 mb-0 d-flex align-items-center gap-2 flex-wrap">
                        {% for logo_src in ent.logos %}
                            <img src="{{ logo_src }}" alt="{{ __('Picture') }}" style="max-height:50px;">
                        {% endfor %}
                        {% if can_edit %}
                        <form method="post" action="{{ entity_form_url }}" enctype="multipart/form-data" class="d-flex align-items-center gap-2 flex-wrap ms-2">
                            <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
                            <input type="hidden" name="entities_id" value="{{ ent.entity_id }}">
                            {{ ent.file_input_html|raw }}
                            <small class="text-muted">({{ ent.max_upload }})</small>
                            <button type="submit" name="add" class="btn btn-sm btn-outline-primary">
                                {{ __('Update logo', 'manageentities') }}
                            </button>
                        </form>
                        {% endif %}
                    </dd>
                </div>
                <hr class="my-2">
                {% endif %}

                {# Entity fields #}
                <form method="post" action="{{ entity_form_url }}">
                    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
                    <input type="hidden" name="entities_id" value="{{ ent.entity_id }}">

                    <dl class="row mb-0">

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('Name') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">
                            {% if ent.is_root_entity %}
                                {{ __('Root entity') }}
                            {% else %}
                                <strong>{{ ent.entity_name }}</strong>
                                <span class="text-muted small ms-1">({{ ent.entity_completename }})</span>
                            {% endif %}
                        </dd>

                        {% if ent.entity_comment %}
                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('Comments') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">{{ ent.entity_comment|nl2br }}</dd>
                        {% endif %}

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('Phone') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">{{ ent.entity_phonenumber }}</dd>

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('Fax') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">{{ ent.entity_fax }}</dd>

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('Website') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">
                            {% if ent.entity_website %}
                                <a href="{{ ent.entity_website }}" target="_blank" rel="noopener">{{ ent.entity_website }}</a>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('Email address') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">
                            {% if ent.entity_email %}
                                <a href="mailto:{{ ent.entity_email }}">{{ ent.entity_email }}</a>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('Address') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">{{ ent.entity_address|nl2br }}</dd>

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('Postal code') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">{{ ent.entity_postcode }}</dd>

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('City') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">{{ ent.entity_town }}</dd>

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('State') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">{{ ent.entity_state }}</dd>

                        <dt class="col-sm-3 text-sm-end text-muted small fw-semibold col-form-label py-1">{{ __('Country') }}</dt>
                        <dd class="col-sm-9 col-form-label py-1">{{ ent.entity_country }}</dd>

                    </dl>

                    {% if can_edit %}
                    <div class="mt-3 text-center">
                        <button type="submit" name="update" class="btn btn-primary">
                            <i class="ti ti-device-floppy me-1"></i>
                            {{ __('Update administrative data', 'manageentities') }}
                        </button>
                    </div>
                    {% endif %}
                </form>

            </div>{# /card-body #}
        </div>{# /card #}
        {% endfor %}

    </div>{# /col left #}

    {# ── Right column — contacts + business (once for all entities) ── #}
    <div class="col-12 col-xl-5 d-flex flex-column gap-3">

        {# Contacts card #}
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-users me-1"></i>
                    {{ _n('Associated contact', 'Associated contacts', 2) }}
                </h3>
            </div>
            <div class="card-body p-0">
                {% if contacts is not empty %}
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>{{ __('Name') }}</th>
                                <th>{{ __('Phone') }}</th>
                                <th>{{ __('Mobile phone') }}</th>
                                <th>{{ __('Email address') }}</th>
                                <th>{{ __('Type') }}</th>
                                {% if can_edit_contacts and is_single %}<th></th>{% endif %}
                            </tr>
                        </thead>
                        <tbody>
                        {% for contact in contacts %}
                            <tr>
                                <td><a href="{{ contact.url }}">{{ contact.name }} {{ contact.firstname }}</a></td>
                                <td>{{ contact.phone }}</td>
                                <td>{{ contact.mobile }}</td>
                                <td>
                                    {% if contact.email %}
                                        <a href="mailto:{{ contact.email }}">{{ contact.email }}</a>
                                    {% endif %}
                                </td>
                                <td>
                                    {{ contact.contact_type }}
                                    {% if is_single and interface != 'helpdesk' %}
                                        <br>
                                        {% if contact.is_default %}
                                            <span class="badge bg-outline-success">{{ __('Manager') }}</span>
                                        {% elseif can_edit_contacts %}
                                            <form method="post" action="{{ entity_action_url }}" class="d-inline">
                                                <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
                                                <input type="hidden" name="contacts_id" value="{{ contact.link_id }}">
                                                <input type="hidden" name="entities_id" value="{{ entity_id }}">
                                                <button type="submit" name="contactbydefault" class="btn btn-link btn-sm p-0">{{ __('Manager') }}</button>
                                            </form>
                                        {% endif %}
                                    {% elseif contact.is_default %}
                                        <br><span class="badge bg-outline-success">{{ __('Manager') }}</span>
                                    {% endif %}
                                </td>
                                {% if can_edit_contacts and is_single %}
                                <td class="text-center">
                                    <form method="post" action="{{ entity_action_url }}" class="d-inline">
                                        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
                                        <input type="hidden" name="id" value="{{ contact.link_id }}">
                                        <button type="submit" name="deletecontacts" class="btn btn-link text-danger p-0" title="{{ __('Delete permanently') }}">
                                            <i class="ti ti-circle-x"></i>
                                        </button>
                                    </form>
                                </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                    <p class="text-muted text-center py-3 mb-0">{{ __('No contact', 'manageentities') }}</p>
                {% endif %}

                {% if can_edit_contacts and is_single %}
                <div class="card-footer">
                    <form method="post" action="{{ entity_action_url }}" class="d-flex align-items-center gap-2 flex-wrap">
                        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
                        <input type="hidden" name="entities_id" value="{{ entity_id }}">
                        <div class="flex-grow-1">{{ contact_dropdown_html|raw }}</div>
                        <a href="{{ contact_form_url }}" target="_blank" title="{{ __('Add') }}">
                            <i class="ti ti-square-plus"></i>
                        </a>
                        <button type="submit" name="addcontacts" class="btn btn-sm btn-primary">{{ __('Add') }}</button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>

        {# Business contacts card #}
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-briefcase me-1"></i>
                    {{ _n('Associated commercial', 'Associated business', 2, 'manageentities') }}
                </h3>
            </div>
            <div class="card-body p-0">
                {% if business is not empty %}
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>{{ __('Name') }}</th>
                                <th>{{ __('Phone') }}</th>
                                <th>{{ __('Phone') }} 2</th>
                                <th>{{ __('Mobile phone') }}</th>
                                <th>{{ __('Email address') }}</th>
                                {% if can_edit_business and is_single %}<th></th>{% endif %}
                            </tr>
                        </thead>
                        <tbody>
                        {% for bc in business %}
                            <tr>
                                <td><a href="{{ bc.url }}">{{ bc.realname }} {{ bc.firstname }}</a></td>
                                <td>{{ bc.phone }}</td>
                                <td>{{ bc.phone2 }}</td>
                                <td>{{ bc.mobile }}</td>
                                <td>
                                    {% if bc.email %}
                                        <a href="mailto:{{ bc.email }}">{{ bc.email }}</a>
                                    {% endif %}
                                </td>
                                {% if can_edit_business and is_single %}
                                <td class="text-center">
                                    <form method="post" action="{{ entity_action_url }}" class="d-inline">
                                        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
                                        <input type="hidden" name="id" value="{{ bc.link_id }}">
                                        <button type="submit" name="deletebusiness" class="btn btn-link text-danger p-0" title="{{ __('Delete permanently') }}">
                                            <i class="ti ti-circle-x"></i>
                                        </button>
                                    </form>
                                </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                    <p class="text-muted text-center py-3 mb-0">{{ __('No business contact', 'manageentities') }}</p>
                {% endif %}

                {% if can_edit_business and is_single %}
                <div class="card-footer">
                    <form method="post" action="{{ entity_action_url }}" class="d-flex align-items-center gap-2 flex-wrap">
                        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
                        <input type="hidden" name="entities_id" value="{{ entity_id }}">
                        <div class="flex-grow-1">{{ user_dropdown_html|raw }}</div>
                        <a href="{{ user_form_url }}" target="_blank" title="{{ __('Add') }}">
                            <i class="ti ti-square-plus"></i>
                        </a>
                        <button type="submit" name="addbusiness" class="btn btn-sm btn-primary">{{ __('Add') }}</button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>

    </div>{# /col right #}
</div>{# /row #}
