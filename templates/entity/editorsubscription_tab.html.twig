<div class="card mt-3">
    <div class="card-header d-flex align-items-center gap-2">
        <h3 class="card-title">
            <i class="ti ti-certificate me-2"></i>
            {{ __('Publisher subscriptions', 'manageentities') }}
            {% set total_count   = rows|length %}
            {% set expired_count = rows|filter(r => r.end_date_expired)|length %}
            {% if total_count > 0 %}
                <span class="badge bg-outline-secondary ms-2">{{ total_count }}</span>
            {% endif %}
            {% if expired_count > 0 %}
                <span class="badge bg-danger-lt ms-1" title="{{ __('Expired subscriptions', 'manageentities') }}">
                    <i class="ti ti-clock-exclamation me-1"></i>{{ expired_count }}
                </span>
            {% endif %}
        </h3>
        <div class="card-options ms-auto d-flex gap-2">
            <button type="button" id="me_sub_filter_expired" class="btn btn-sm btn-outline-warning"
                    title="{{ __('Show expired subscriptions only', 'manageentities') }}">
                <i class="ti ti-clock-exclamation me-1"></i>{{ __('Expired only', 'manageentities') }}
            </button>
            <a href="{{ export_url }}" id="me_sub_export_btn" class="btn btn-sm btn-outline-secondary">
                <i class="ti ti-table-export me-1"></i>{{ __('Export CSV', 'manageentities') }}
            </a>
            {% if can_edit %}
            <a href="{{ wizard_url }}" class="btn btn-sm btn-outline-success">
                <i class="ti ti-plus me-1"></i>{{ __('Create subscription', 'manageentities') }}
            </a>
            {% endif %}
        </div>
    </div>

    {% if missing_entities|length > 0 %}
    <div class="alert alert-danger alert-important d-flex align-items-start gap-2 mb-0 border-0 rounded-0" role="alert">
        <i class="ti ti-alert-triangle flex-shrink-0 mt-1"></i>
        <div>
            <strong>{{ __('The following entities have no publisher subscription:', 'manageentities') }}</strong>
            <ul class="mb-0 mt-1">
                {% for name in missing_entities %}
                    <li>{{ name }}</li>
                {% endfor %}
            </ul>
        </div>
    </div>
    {% endif %}

    <div class="card-body p-0">
        {% if rows|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0" id="me_sub_table">
                <thead>
                    <tr>
                        <th data-col="0" class="me-sub-sortable" style="cursor:pointer;white-space:nowrap;">{{ _n('Entity', 'Entities', 1) }} <i class="ti ti-arrows-sort ms-1 text-muted"></i></th>
                        <th data-col="1" class="me-sub-sortable" style="cursor:pointer;white-space:nowrap;">{{ __('Publisher customer account ID', 'manageentities') }} <i class="ti ti-arrows-sort ms-1 text-muted"></i></th>
                        <th data-col="2" class="me-sub-sortable" style="cursor:pointer;white-space:nowrap;">{{ __('Referenced name at the publisher', 'manageentities') }} <i class="ti ti-arrows-sort ms-1 text-muted"></i></th>
                        <th data-col="3" class="text-center me-sub-sortable" style="cursor:pointer;white-space:nowrap;">{{ __('Type', 'manageentities') }} <i class="ti ti-arrows-sort ms-1 text-muted"></i></th>
                        <th data-col="4" class="me-sub-sortable" style="cursor:pointer;white-space:nowrap;">{{ __('Subscription level', 'manageentities') }} <i class="ti ti-arrows-sort ms-1 text-muted"></i></th>
                        <th data-col="5" class="me-sub-sortable" style="cursor:pointer;white-space:nowrap;">{{ __('Start date', 'manageentities') }} <i class="ti ti-arrows-sort ms-1 text-muted"></i></th>
                        <th data-col="6" class="me-sub-sortable" style="cursor:pointer;white-space:nowrap;">{{ __('End date', 'manageentities') }} <i class="ti ti-arrows-sort ms-1 text-muted"></i></th>
                        {% if can_edit %}<th></th>{% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                    <tr data-expired="{{ row.end_date_expired ? '1' : '0' }}">
                        <td>{{ row.entity_completename ?: '—' }}</td>
                        <td>{{ row.customer_account_id ?: '—' }}</td>
                        <td>{{ row.name ?: '—' }}</td>
                        <td class="text-center">
                            {% if row.cloud_client %}
                                <span class="badge bg-outline-info"><i class="ti ti-cloud me-1"></i>{{ __('Cloud', 'manageentities') }}</span>
                            {% else %}
                                <span class="badge bg-outline-success"><i class="ti ti-certificate me-1"></i>{{ __('Editor', 'manageentities') }}</span>
                            {% endif %}
                        </td>
                        <td>{{ row.level_name ?: '—' }}</td>
                        <td data-sort="{{ row.begin_date ? row.begin_date|date('Y-m-d') : '' }}">{{ row.begin_date ? row.begin_date|date('d/m/Y') : '—' }}</td>
                        <td class="{% if row.end_date_expired %}text-danger fw-bold{% endif %}"
                            data-sort="{{ row.end_date ? row.end_date|date('Y-m-d') : '' }}">
                            {{ row.end_date ? row.end_date|date('d/m/Y') : '—' }}
                            {% if row.end_date_expired %}<i class="ti ti-alert-circle ms-1"></i>{% endif %}
                        </td>
                        {% if can_edit %}
                        <td class="text-end">
                            <a href="{{ wizard_url }}?entities_id={{ row.entities_id }}"
                               class="btn btn-sm btn-outline-primary">
                                <i class="ti ti-pencil me-1"></i>{{ __('Edit') }}
                            </a>
                        </td>
                        {% endif %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="p-3 text-muted">
            <i class="ti ti-info-circle me-1"></i>
            {{ __('No publisher subscription recorded for this entity.', 'manageentities') }}
        </div>
        {% endif %}
    </div>
</div>

<script>
(function () {
    /* ---- expired filter ---- */
    var btn       = document.getElementById('me_sub_filter_expired');
    var exportBtn = document.getElementById('me_sub_export_btn');

    var baseExportUrl    = {{ export_url|json_encode|raw }};
    var expiredExportUrl = baseExportUrl + '&sub_expired=1';
    var filterActive     = false;

    if (btn) {
        btn.addEventListener('click', function () {
            filterActive = !filterActive;
            btn.classList.toggle('btn-outline-warning', !filterActive);
            btn.classList.toggle('btn-warning',          filterActive);

            document.querySelectorAll('#me_sub_table tbody tr').forEach(function (tr) {
                if (filterActive) {
                    tr.style.display = tr.getAttribute('data-expired') === '1' ? '' : 'none';
                } else {
                    tr.style.display = '';
                }
            });

            if (exportBtn) {
                exportBtn.href = filterActive ? expiredExportUrl : baseExportUrl;
            }
        });
    }

    /* ---- column sort ---- */
    var table = document.getElementById('me_sub_table');
    if (!table) { return; }
    var sortCol = -1;
    var sortAsc = true;

    function cellVal(tr, col) {
        var td = tr.querySelectorAll('td')[col];
        if (!td) { return ''; }
        var v = td.getAttribute('data-sort');
        if (v === null) { v = td.textContent; }
        v = v.trim();
        return (v === '' || v === '—') ? '￿' : v.toLowerCase();
    }

    table.querySelectorAll('th.me-sub-sortable').forEach(function (th) {
        th.addEventListener('click', function () {
            var col = parseInt(th.getAttribute('data-col'), 10);
            if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }

            table.querySelectorAll('th.me-sub-sortable i').forEach(function (i) {
                i.className = 'ti ti-arrows-sort ms-1 text-muted';
            });
            th.querySelector('i').className = sortAsc
                ? 'ti ti-sort-ascending ms-1 text-primary'
                : 'ti ti-sort-descending ms-1 text-primary';

            var tbody = table.querySelector('tbody');
            var trs   = Array.from(tbody.querySelectorAll('tr'));
            trs.sort(function (a, b) {
                var va = cellVal(a, col);
                var vb = cellVal(b, col);
                if (va === vb) { return 0; }
                var gt = va > vb;
                return sortAsc ? (gt ? 1 : -1) : (gt ? -1 : 1);
            });
            trs.forEach(function (tr) { tbody.appendChild(tr); });
        });
    });
})();
</script>
