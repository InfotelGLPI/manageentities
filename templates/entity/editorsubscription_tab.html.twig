<div class="card mt-3">
    <div class="card-header d-flex align-items-center gap-2">
        <h3 class="card-title">
            <i class="ti ti-certificate me-2"></i>
            {{ __('Publisher subscriptions', 'manageentities') }}
            {% set expired_count = rows|filter(r => r.end_date_expired)|length %}
            {% if expired_count > 0 %}
                <span class="badge bg-outline-danger ms-2">{{ expired_count }}</span>
            {% endif %}
        </h3>
        <div class="card-options ms-auto d-flex gap-2">
            <button type="button" id="me_sub_filter_expired" class="btn btn-sm btn-outline-warning"
                    title="{{ __('Show expired subscriptions only', 'manageentities') }}">
                <i class="ti ti-clock-exclamation me-1"></i>{{ __('Expired only', 'manageentities') }}
            </button>
            <a href="{{ export_url }}" id="me_sub_export_btn" class="btn btn-sm btn-outline-secondary">
                <i class="ti ti-table-export me-1"></i>{{ __('Export CSV', 'manageentities') }}
            </a>
            {% if can_edit %}
            <a href="{{ wizard_url }}" class="btn btn-sm btn-outline-success">
                <i class="ti ti-plus me-1"></i>{{ __('Create subscription', 'manageentities') }}
            </a>
            {% endif %}
        </div>
    </div>

    <div class="card-body p-0">
        {% if rows|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead>
                    <tr>
                        <th>{{ _n('Entity', 'Entities', 1) }}</th>
                        <th>{{ __('Publisher customer account ID', 'manageentities') }}</th>
                        <th>{{ __('Referenced name at the publisher', 'manageentities') }}</th>
                        <th class="text-center">{{ __('Type', 'manageentities') }}</th>
                        <th>{{ __('Subscription level', 'manageentities') }}</th>
                        <th>{{ __('Start date', 'manageentities') }}</th>
                        <th>{{ __('End date', 'manageentities') }}</th>
                        {% if can_edit %}<th></th>{% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                    <tr data-expired="{{ row.end_date_expired ? '1' : '0' }}">
                        <td>{{ row.entity_completename ?: '—' }}</td>
                        <td>{{ row.customer_account_id ?: '—' }}</td>
                        <td>{{ row.name ?: '—' }}</td>
                        <td class="text-center">
                            {% if row.cloud_client %}
                                <span class="badge bg-outline-info"><i class="ti ti-cloud me-1"></i>{{ __('Cloud', 'manageentities') }}</span>
                            {% else %}
                                <span class="badge bg-outline-success"><i class="ti ti-certificate me-1"></i>{{ __('Editor', 'manageentities') }}</span>
                            {% endif %}
                        </td>
                        <td>{{ row.level_name ?: '—' }}</td>
                        <td>{{ row.begin_date ? row.begin_date|date('d/m/Y') : '—' }}</td>
                        <td class="{% if row.end_date_expired %}text-danger fw-bold{% endif %}">
                            {{ row.end_date ? row.end_date|date('d/m/Y') : '—' }}
                            {% if row.end_date_expired %}<i class="ti ti-alert-circle ms-1"></i>{% endif %}
                        </td>
                        {% if can_edit %}
                        <td class="text-end">
                            <a href="{{ wizard_url }}?entities_id={{ row.entities_id }}"
                               class="btn btn-sm btn-outline-primary">
                                <i class="ti ti-pencil me-1"></i>{{ __('Edit') }}
                            </a>
                        </td>
                        {% endif %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="p-3 text-muted">
            <i class="ti ti-info-circle me-1"></i>
            {{ __('No publisher subscription recorded for this entity.', 'manageentities') }}
        </div>
        {% endif %}
    </div>
</div>

<script>
(function () {
    var btn       = document.getElementById('me_sub_filter_expired');
    var exportBtn = document.getElementById('me_sub_export_btn');
    if (!btn) { return; }

    var baseExportUrl    = {{ export_url|json_encode|raw }};
    var expiredExportUrl = baseExportUrl + '&sub_expired=1';
    var active           = false;

    btn.addEventListener('click', function () {
        active = !active;
        btn.classList.toggle('btn-outline-warning', !active);
        btn.classList.toggle('btn-warning',         active);

        var rows = document.querySelectorAll('[data-expired]');
        rows.forEach(function (tr) {
            if (active) {
                tr.style.display = tr.getAttribute('data-expired') === '1' ? '' : 'none';
            } else {
                tr.style.display = '';
            }
        });

        if (exportBtn) {
            exportBtn.href = active ? expiredExportUrl : baseExportUrl;
        }
    });
})();
</script>
